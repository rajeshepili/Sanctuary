{
  "version": "1.0.0",
  "name": "sanctuary",
  "author": {
    "name": "Rajesh Epili",
    "email": "rajeshepili@users.noreply.github.com"
  },
  "description": "Sanctuary — a local, private journal and habit tracking app",
  "license": "MIT",
  "homepage": "https://github.com/rajeshepili/sanctuary",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rajeshepili/sanctuary.git"
  },
  "bugs": {
    "url": "https://github.com/rajeshepili/sanctuary/issues"
  },
  "packageManager": "pnpm@10.0.0",
  "main": ".output/main.js",
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "desktop:dev": "pnpm desktop:build:main && concurrently \"pnpm dev\" \"wait-on tcp:3000 && electron .\"",
    "desktop:icon": "node scripts/generate-icons.js",
    "desktop:build:main": "esbuild main.ts --bundle --platform=node --format=esm --external:electron --external:electron-updater --outfile=.output/main.js",
    "desktop:build": "pnpm desktop:icon && pnpm build && pnpm desktop:build:main && electron-builder",
    "desktop:build:appimage": "pnpm desktop:icon && pnpm build && pnpm desktop:build:main && electron-builder --linux AppImage",
    "desktop:build:deb": "pnpm desktop:icon && pnpm build && pnpm desktop:build:main && electron-builder --linux deb",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node scripts/test-runner.js all",
    "test:unit": "node scripts/test-runner.js unit",
    "test:integration": "node scripts/test-runner.js integration",
    "test:watch": "node scripts/test-runner.js watch",
    "test:coverage": "node scripts/test-runner.js coverage",
    "test:ci": "node scripts/test-runner.js unit && node scripts/test-runner.js integration",
    "lint": "eslint src",
    "format": "prettier --write . && eslint --fix",
    "check": "prettier --check src README.md CONTRIBUTING.md CHANGELOG.md CODE_OF_CONDUCT.md SECURITY.md docs main.ts scripts .github package.json electron-builder.yml",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:run": "tsx src/database/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:pull": "drizzle-kit pull",
    "db:studio": "drizzle-kit studio",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@hookform/resolvers": "^5.4.0",
    "@libsql/client": "^0.17.3",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-devtools": "^0.10.5",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-router": "^1.170.10",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-router-ssr-query": "^1.167.1",
    "@tanstack/react-start": "^1.168.17",
    "@tanstack/router-plugin": "^1.168.13",
    "@tiptap/extension-bubble-menu": "^3.25.0",
    "@tiptap/extension-placeholder": "^3.25.0",
    "@tiptap/markdown": "^3.25.0",
    "@tiptap/react": "^3.25.0",
    "@tiptap/starter-kit": "^3.25.0",
    "@types/mdast": "^4.0.4",
    "@uiw/react-md-editor": "^4.1.1",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "electron-updater": "^6.8.3",
    "embla-carousel-react": "^8.6.0",
    "file-type": "^22.0.1",
    "framer-motion": "^12.40.0",
    "fs-extra": "^11.3.5",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.17.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.76.1",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.11.2",
    "recharts": "3.8.1",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.10.0",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "suncalc": "^1.9.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "three": "^0.184.0",
    "tw-animate-css": "^1.4.0",
    "unist-util-visit": "^5.1.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/devtools-vite": "^0.7.0",
    "@tanstack/eslint-config": "^0.4.0",
    "@tanstack/eslint-plugin-query": "^5.100.14",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/suncalc": "^1.9.2",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^6.0.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^10.0.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "electron": "^32.3.3",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.6",
    "nitro": "3.0.260522-beta",
    "prettier": "^3.8.3",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7",
    "wait-on": "^9.0.10"
  }
}
